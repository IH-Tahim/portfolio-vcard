---
import Layout from '../layouts/Layout.astro';
---

<Layout title="My Contact Card | Portfolio">
  <section class="min-h-[80vh] flex flex-col justify-center items-center py-20 px-4 max-w-lg mx-auto text-center">
    <!-- Profile Photo -->
    <div class="w-32 h-32 rounded-full overflow-hidden mb-6 border-4 border-burntorange animate-on-scroll">
      <img src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?ixlib=rb-4.0.3&auto=format&fit=facearea&facepad=2&w=256&h=256&q=80" alt="Profile Photo" class="w-full h-full object-cover" />
    </div>
    
    <h1 class="text-4xl font-syne font-bold mb-2 animate-on-scroll" style="transition-delay: 100ms;">Tahim</h1>
    <p class="text-lg opacity-80 mb-8 animate-on-scroll" style="transition-delay: 200ms;">Front-End Web Developer</p>
    
    <!-- Massive Save Contact Button -->
    <a href="/vcard.vcf" download class="w-full py-6 bg-burntorange text-white text-xl font-bold rounded-2xl hover:bg-burntorange/90 hover:scale-[1.02] transition-all shadow-lg shadow-burntorange/25 mb-12 animate-on-scroll flex justify-center items-center gap-3" style="transition-delay: 300ms;">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
      Save Contact
    </a>

    <!-- Contact Exchange Form -->
    <div class="w-full bg-charcoal/5 dark:bg-offwhite/5 p-8 rounded-3xl animate-on-scroll" style="transition-delay: 400ms;">
      <h3 class="text-2xl font-syne font-bold mb-6">Share Your Info</h3>
      <form action="https://api.web3forms.com/submit" method="POST" class="space-y-4 text-left">
        <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE" />
        <input type="hidden" name="subject" value="New Contact Exchange from NFC Card" />
        
        <div>
          <label class="block text-sm font-medium mb-1">Name</label>
          <input type="text" name="name" required class="w-full px-4 py-3 rounded-xl bg-white dark:bg-charcoal border border-charcoal/10 dark:border-offwhite/10 focus:border-burntorange outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Email</label>
          <input type="email" name="email" required class="w-full px-4 py-3 rounded-xl bg-white dark:bg-charcoal border border-charcoal/10 dark:border-offwhite/10 focus:border-burntorange outline-none transition-colors" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Phone (Optional)</label>
          <input type="tel" name="phone" class="w-full px-4 py-3 rounded-xl bg-white dark:bg-charcoal border border-charcoal/10 dark:border-offwhite/10 focus:border-burntorange outline-none transition-colors" />
        </div>
        
        <button type="submit" class="w-full py-4 bg-charcoal text-offwhite dark:bg-offwhite dark:text-charcoal font-semibold rounded-xl hover:opacity-90 transition-opacity mt-4">
          Connect
        </button>
      </form>
    </div>
    
    <!-- Social Links -->
    <div class="flex gap-6 mt-12 animate-on-scroll" style="transition-delay: 500ms;">
      <a href="#" class="w-12 h-12 rounded-full bg-charcoal/10 dark:bg-offwhite/10 flex items-center justify-center hover:bg-burntorange hover:text-white transition-colors">in</a>
      <a href="#" class="w-12 h-12 rounded-full bg-charcoal/10 dark:bg-offwhite/10 flex items-center justify-center hover:bg-burntorange hover:text-white transition-colors">tw</a>
      <a href="#" class="w-12 h-12 rounded-full bg-charcoal/10 dark:bg-offwhite/10 flex items-center justify-center hover:bg-burntorange hover:text-white transition-colors">gh</a>
    </div>
  </section>
</Layout>
