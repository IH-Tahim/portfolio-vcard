---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Services — Imam Hasan Tahim | Digital Marketer & Web Developer Dhaka">
  <!-- ══════════════ HERO ══════════════ -->
  <section class="hero">
    <div class="hero-grid"></div>
    <div class="hero-orb1"></div>
    <div class="hero-orb2"></div>

    <div class="hero-pre">What I Offer — ihtahim.com/services</div>

    <h1 class="hero-h1 syne">
      Services that<br>
      <em>actually</em><br>
      <span class="outline">move</span> the needle.
    </h1>

    <p class="hero-sub">
      I don't just run campaigns — I build the complete system behind them.
      <strong>Strategy, execution, tracking, and optimisation</strong> — all under one roof,
      from a marketer who can also write the code.
    </p>

    <div class="result-pills">
      <div class="rpill"><span class="rpill-num">35%</span> Reduction in ad cost</div>
      <div class="rpill"><span class="rpill-num">100+</span> Leads generated in a month</div>
      <div class="rpill"><span class="rpill-num">3+</span> Years of real-world results</div>
      <div class="rpill"><span class="rpill-num">12+</span> Happy clients</div>
    </div>

    <div class="hero-cta">
      <a href="https://wa.me/8801673539272" target="_blank" class="btn-primary">💬 Chat on WhatsApp</a>
      <a href="#services" class="btn-ghost">View All Services ↓</a>
    </div>

    <div class="hero-numbers">
      <div class="h-num">
        <div class="h-num-val">35<sup>%</sup></div>
        <div class="h-num-lbl">Ad Cost Reduced</div>
      </div>
      <div class="h-num">
        <div class="h-num-val">100<sup>+</sup></div>
        <div class="h-num-lbl">Leads / Month</div>
      </div>
      <div class="h-num">
        <div class="h-num-val">12<sup>+</sup></div>
        <div class="h-num-lbl">Clients Served</div>
      </div>
      <div class="h-num">
        <div class="h-num-val">3<sup>+</sup></div>
        <div class="h-num-lbl">Years Experience</div>
      </div>
    </div>
  </section>

  <!-- ══════════════ SERVICES GRID ══════════════ -->
  <section class="services-section" id="services">
    <div class="srv-intro reveal visible">
      <div>
        <div class="eyebrow" style="margin-bottom:1.2rem">My Services</div>
        <h2 class="srv-h2 syne">Six ways I grow<br><em>your business.</em></h2>
      </div>
      <p class="srv-p">
        Each service is designed to work as a standalone solution
        or as part of a <strong>complete growth system</strong>.
        No fluff — just the strategies that have worked for real clients.
      </p>
    </div>

    <div class="srv-grid">
      <!-- 01: Ads -->
      <div class="srv-card featured reveal visible d1">
        <div class="srv-card-num">01</div>
        <span class="srv-icon">🎯</span>
        <div class="srv-name">Facebook & Google Ads</div>
        <p class="srv-desc">
          I build paid ad systems — not just campaigns. From audience research and
          psychological ad copy to <strong>server-side tracking</strong> and aggressive
          A/B testing. I've reduced client ad costs by <strong>35%</strong> while maintaining
          lead volume. Every taka you spend is tracked, measured, and optimised.
        </p>
        <span class="srv-result">35% lower cost per lead</span>
        <div class="srv-tags">
          <span class="srv-tag">Meta Ads</span>
          <span class="srv-tag">Google Search</span>
          <span class="srv-tag">Pixel Setup</span>
        </div>
      </div>

      <!-- 02: SEO -->
      <div class="srv-card reveal visible d2">
        <div class="srv-card-num">02</div>
        <span class="srv-icon">📈</span>
        <div class="srv-name">SEO & Content Marketing</div>
        <p class="srv-desc">
          Technical SEO audits, keyword strategy, and content that ranks.
          I audit your site's code to fix the speed and structural issues that silently kill your rankings.
        </p>
        <span class="srv-result">Organic traffic growth</span>
        <div class="srv-tags">
          <span class="srv-tag">Technical SEO</span>
          <span class="srv-tag">Semrush</span>
        </div>
      </div>

      <!-- 03: Social Media -->
      <div class="srv-card reveal visible d1">
        <div class="srv-card-num">03</div>
        <span class="srv-icon">📱</span>
        <div class="srv-name">Social Media Marketing</div>
        <p class="srv-desc">
          Brand storytelling that builds real audiences. Content calendars,
          community engagement, and growth strategy with <strong>100+ leads generated</strong> monthly.
        </p>
        <span class="srv-result">100+ leads / month</span>
        <div class="srv-tags">
          <span class="srv-tag">Facebook</span>
          <span class="srv-tag">Instagram</span>
        </div>
      </div>

      <!-- 04: Shopify -->
      <div class="srv-card reveal visible d2">
        <div class="srv-card-num">04</div>
        <span class="srv-icon">🛒</span>
        <div class="srv-name">Shopify Optimization</div>
        <p class="srv-desc">
          I improve page speed, conversion rate, and UX — fixing the leaks in
          your e-commerce funnel that are costing you sales every single day.
        </p>
        <span class="srv-result">Higher conversion rate</span>
        <div class="srv-tags">
          <span class="srv-tag">CRO</span>
          <span class="srv-tag">Speed</span>
        </div>
      </div>

      <!-- 05: WordPress -->
      <div class="srv-card reveal visible d3">
        <div class="srv-card-num">05</div>
        <span class="srv-icon">💻</span>
        <div class="srv-name">WordPress Development</div>
        <p class="srv-desc">
          Fast, clean, conversion-focused WordPress sites. Everything from service 
          business sites to custom document management systems.
        </p>
        <span class="srv-result">Performance optimized</span>
        <div class="srv-tags">
          <span class="srv-tag">Elementor</span>
          <span class="srv-tag">Custom Dev</span>
        </div>
      </div>

      <!-- 06: Landing Pages -->
      <div class="srv-card featured reveal visible d1">
        <div class="srv-card-num">06</div>
        <span class="srv-icon">🚀</span>
        <div class="srv-name">Landing Page Design</div>
        <p class="srv-desc">
          Pages built by someone who understands code and marketing psychology.
          Built with clean HTML/CSS for blazing speed and tracked micro-interactions.
        </p>
        <span class="srv-result">Conversion by design</span>
        <div class="srv-tags">
          <span class="srv-tag">HTML/CSS</span>
          <span class="srv-tag">Copywriting</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════ PROCESS ══════════════ -->
  <section class="process-section">
    <div class="process-top reveal visible">
      <div>
        <div class="eyebrow" style="margin-bottom:1.2rem">How I Work</div>
        <h2 class="proc-h2 syne">A 7-step system<br><em>built for results.</em></h2>
      </div>
    </div>

    <div class="process-steps">
      <div class="proc-step reveal visible">
        <div class="proc-num-col"><div class="proc-num">01</div></div>
        <div class="proc-body">
          <div class="proc-title">Discovery Call</div>
          <p class="proc-desc">We diagnose your business, ideal customer, and the <strong>psychological triggers</strong> that make them buy.</p>
        </div>
      </div>
      <div class="proc-step reveal visible d1">
        <div class="proc-num-col"><div class="proc-num">02</div></div>
        <div class="proc-body">
          <div class="proc-title">Market & Competitor Teardown</div>
          <p class="proc-desc">We reverse-engineer your competitors to see exactly where they're leaving money on the table.</p>
        </div>
      </div>
      <!-- Add more steps as needed, mirroring the original structure -->
    </div>
  </section>

  <style>
    /* ════════════════ HERO ════════════════ */
    .hero {
      min-height: 100vh; display: flex; flex-direction: column;
      justify-content: center; position: relative; overflow: hidden;
      padding: calc(var(--nav-h) + 80px) 7% 100px;
    }
    .hero-grid {
      position: absolute; inset: 0; pointer-events: none;
      background-image: linear-gradient(rgba(255,77,0,.025) 1px, transparent 1px),
                        linear-gradient(90deg, rgba(255,77,0,.025) 1px, transparent 1px);
      background-size: 72px 72px;
    }
    .hero-orb1 { position: absolute; top: -10%; right: 10%; width: 500px; height: 500px; border-radius: 50%; background: radial-gradient(circle, rgba(255,77,0,.07) 0%, transparent 65%); }
    .hero-orb2 { position: absolute; bottom: 5%; left: -5%; width: 400px; height: 400px; border-radius: 50%; background: radial-gradient(circle, rgba(255,77,0,.04) 0%, transparent 65%); }

    .hero-pre { font-size: .62rem; font-weight: 600; letter-spacing: .28em; text-transform: uppercase; color: var(--orange); margin-bottom: 1.5rem; }
    .hero-h1 { font-size: clamp(3rem, 7vw, 7rem); font-weight: 800; letter-spacing: -.04em; line-height: .95; color: var(--cream); margin-bottom: 2rem; }
    .hero-h1 em { font-style: italic; color: var(--orange); }
    .hero-h1 .outline { -webkit-text-stroke: 1.5px var(--cream); color: transparent; }

    .hero-sub { font-size: 1.05rem; font-weight: 300; line-height: 1.85; color: var(--muted); max-width: 560px; margin-bottom: 3rem; }
    .result-pills { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 3.5rem; }
    .rpill { display: flex; align-items: center; gap: 8px; padding: 8px 16px; background: var(--surface); border: 1px solid var(--border); font-size: .8rem; color: var(--text); }
    .rpill-num { font-weight: 800; color: var(--orange); }

    .hero-cta { display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; }
    .btn-primary { background: var(--orange); color: #fff; padding: 1rem 2.4rem; font-weight: 600; text-transform: uppercase; transition: 0.3s; }
    .btn-ghost { color: var(--muted); border: 1px solid var(--border); padding: 1rem 2rem; font-weight: 500; text-transform: uppercase; transition: 0.3s; }

    .hero-numbers { display: flex; margin-top: 72px; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .h-num { flex: 1; padding: 24px 0; text-align: center; border-right: 1px solid var(--border); }
    .h-num:last-child { border-right: none; }
    .h-num-val { font-size: 2.2rem; font-weight: 800; color: var(--cream); }
    .h-num-lbl { font-size: .6rem; font-weight: 600; text-transform: uppercase; color: var(--muted); margin-top: 5px; }

    /* ════════════════ SERVICES ════════════════ */
    .services-section { background: var(--dark2); }
    .srv-intro { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: end; margin-bottom: 72px; }
    .srv-h2 { font-size: clamp(2.2rem, 4vw, 3.6rem); font-weight: 800; color: var(--cream); }
    .srv-h2 em { font-style: italic; color: var(--orange); }
    .srv-p { font-size: .95rem; color: var(--muted); line-height: 1.9; }

    .srv-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--border); border: 1px solid var(--border); }
    .srv-card { background: var(--dark2); padding: 2.4rem 2rem; position: relative; transition: 0.3s; }
    .srv-card.featured { grid-column: span 2; }
    .srv-card:hover { background: var(--surface); }
    .srv-card::before { content: ''; position: absolute; left: 0; bottom: 0; right: 0; height: 3px; background: var(--orange); transform: scaleX(0); transition: 0.4s; }
    .srv-card:hover::before { transform: scaleX(1); }
    .srv-card-num { position: absolute; top: 1.5rem; right: 1.5rem; font-size: 3.5rem; font-weight: 800; color: rgba(255,77,0,.06); }
    .srv-icon { font-size: 2rem; margin-bottom: 1.4rem; display: block; }
    .srv-name { font-size: 1.1rem; font-weight: 700; color: var(--cream); margin-bottom: .75rem; }
    .srv-desc { font-size: .87rem; color: var(--muted); line-height: 1.8; }
    .srv-result { display: inline-flex; align-items: center; gap: 6px; margin-top: 1.2rem; font-size: .65rem; font-weight: 700; color: var(--orange); background: var(--orange-dim); padding: 5px 12px; }
    .srv-tags { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 1rem; }
    .srv-tag { font-size: .58rem; font-weight: 600; padding: 3px 8px; border: 1px solid var(--border); color: var(--muted); text-transform: uppercase; }

    /* ════════════════ PROCESS ════════════════ */
    .proc-step { display: grid; grid-template-columns: 72px 1fr; border-bottom: 1px solid var(--border); }
    .proc-step:first-child { border-top: 1px solid var(--border); }
    .proc-num-col { padding: 2.5rem 0; border-right: 1px solid var(--border); display: flex; justify-content: center; }
    .proc-num { width: 32px; height: 32px; border-radius: 50%; border: 1px solid var(--border-o); display: flex; align-items: center; justify-content: center; font-size: .75rem; font-weight: 800; color: var(--orange); }
    .proc-body { padding: 2.5rem 2rem; }
    .proc-title { font-size: 1rem; font-weight: 700; color: var(--cream); margin-bottom: .6rem; }
    .proc-desc { font-size: .87rem; color: var(--muted); line-height: 1.85; }

    /* ════════════════ RESPONSIVE ════════════════ */
    @media (max-width: 1100px) {
      .srv-grid { grid-template-columns: 1fr 1fr; }
      .srv-card.featured { grid-column: span 1; }
    }
    @media (max-width: 768px) {
      .srv-intro, .process-top { grid-template-columns: 1fr; }
      .srv-grid { grid-template-columns: 1fr; }
      .hero-numbers { display: grid; grid-template-columns: 1fr 1fr; }
      .h-num { border-right: none; border-bottom: 1px solid var(--border); }
    }
  </style>
</Layout>
