---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About — Imam Hasan Tahim | Digital Marketer & Web Developer">
  <!-- ═══════ SECTION 1 — HERO ═══════ -->
  <section class="about-hero">
    <div class="about-hero-bg"></div>
    <div class="about-hero-grid"></div>

    <div class="about-hero-photo">
      <div class="photo-frame reveal visible">
        <div class="photo-accent-bar"></div>
        <!-- Using the original demo image structure -->
        <img class="photo-main" src="/images/about_hero.png" alt="Imam Hasan Tahim" />
        
        <div class="photo-quote-badge">
          <div class="quote-text">"Marketing is no longer about the stuff that you make, but about the stories you tell."</div>
          <div class="quote-attr">— Seth Godin</div>
        </div>
      </div>
    </div>

    <div class="about-hero-content">
      <div class="eyebrow about-hero-eyebrow">The person behind the work</div>
      <h1 class="about-hero-headline syne">Helping brands<br><em>grow & thrive.</em></h1>
      <p class="about-hero-sub">
        I am <strong>Imam Hasan Tahim</strong>, a dedicated Digital Marketer and Web Developer based in Dhaka. 
        I specialize in bridging the gap between technical execution and creative marketing strategy.
      </p>

      <div class="hero-pills">
        <span class="pill highlight">3+ Years Exp.</span>
        <span class="pill">Digital Strategy</span>
        <span class="pill">Paid Media</span>
        <span class="pill">Web Dev</span>
      </div>

      <div class="role-card">
        <div class="role-dot"></div>
        <div>
          <div class="role-text">Currently IT Manager</div>
          <div class="role-sub">at Spotless4u</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ SECTION 2 — STORY ═══════ -->
  <section class="story-section">
    <div class="story-wrap">
      <div class="story-chapters">
        <div class="chapter reveal visible">
          <div class="chapter-num">Chapter 01</div>
          <h2 class="chapter-title">The Foundation</h2>
          <p class="chapter-body">
            My journey began with a curiosity for how the internet works. What started as simple HTML tweaks evolved into a deep passion for <strong>Conversion Rate Optimization (CRO)</strong> and <strong>Performance Marketing</strong>.
          </p>
        </div>

        <div class="chapter reveal visible d1">
          <div class="chapter-num">Chapter 02</div>
          <h2 class="chapter-title">The Growth Mindset</h2>
          <p class="chapter-body">
            I believe that every click should have a purpose. Over the last 3 years, I've managed significant ad spend across Meta and Google, always focusing on the <strong>Return on Investment (ROI)</strong> for my clients.
          </p>
        </div>

        <div class="chapter reveal visible d2">
          <div class="chapter-num">Chapter 03</div>
          <h2 class="chapter-title">The Future</h2>
          <p class="chapter-body">
            Today, I combine my technical background with marketing expertise to build <strong>full-funnel solutions</strong>. From the first ad impression to the final checkout, I optimize every step of the user journey.
          </p>
        </div>
      </div>

      <div class="story-visual reveal visible d3">
        <div class="story-photo-wrap">
          <img src="/images/story_photo.png" alt="Working on strategy" />
          <div class="story-photo-label">
            <div class="story-photo-label-text">Focused on Results</div>
            <div class="story-photo-label-sub">Strategy session, 2024</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ SECTION 3 — EXPERIENCE ═══════ -->
  <section class="exp-section" id="experience">
    <div class="eyebrow" style="margin-bottom:1.5rem">Professional Path</div>
    <h2 class="syne" style="font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 3rem; color: var(--cream);">Work Experience</h2>

    <div class="exp-grid">
      <div class="exp-item reveal visible">
        <div class="exp-meta">
          <div class="exp-period">2022 — Present</div>
          <div class="exp-company">Spotless4u</div>
          <div class="exp-location">Dhaka, Bangladesh</div>
        </div>
        <div class="exp-content">
          <h3 class="exp-role">IT Manager & Digital Lead</h3>
          <p class="exp-desc">
            Overseeing the entire digital infrastructure and marketing efforts. Managed <strong>Facebook & Google Ads</strong>, optimized website performance, and implemented automated lead generation systems.
          </p>
          <div class="exp-tags">
            <span class="exp-tag">Management</span>
            <span class="exp-tag">Ads Strategy</span>
            <span class="exp-tag">Technical SEO</span>
          </div>
        </div>
      </div>

      <div class="exp-item reveal visible d1">
        <div class="exp-meta">
          <div class="exp-period">2021 — 2022</div>
          <div class="exp-company">Freelance</div>
          <div class="exp-location">Remote</div>
        </div>
        <div class="exp-content">
          <h3 class="exp-role">Web Developer & SEM Specialist</h3>
          <p class="exp-desc">
            Worked with various small businesses to establish their online presence. Specialized in <strong>WordPress development</strong> and high-converting landing pages.
          </p>
          <div class="exp-tags">
            <span class="exp-tag">WordPress</span>
            <span class="exp-tag">Landing Pages</span>
            <span class="exp-tag">Google Ads</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ SECTION 4 — TOOLS ═══════ -->
  <section class="tools-section">
    <div class="tools-intro">
      <div>
        <div class="eyebrow" style="margin-bottom:1.2rem">My Stack</div>
        <h2 class="tools-headline syne">Tools &amp; <em>Technologies.</em></h2>
      </div>
      <p class="tools-text">
        I use a curated selection of industry-leading tools to ensure maximum efficiency, 
        security, and performance for every project I handle.
      </p>
    </div>

    <div class="tools-categories">
      <div>
        <div class="tool-cat-label">Marketing &amp; Ads</div>
        <div class="tools-row">
          <div class="tool-pill"><span class="tool-emoji">📊</span> Meta Ads Manager</div>
          <div class="tool-pill"><span class="tool-emoji">🎯</span> Google Ads</div>
          <div class="tool-pill"><span class="tool-emoji">📈</span> Google Analytics 4</div>
          <div class="tool-pill"><span class="tool-emoji">🛡️</span> Google Tag Manager</div>
          <div class="tool-pill"><span class="tool-emoji">🔍</span> SEMrush</div>
        </div>
      </div>

      <div>
        <div class="tool-cat-label">Development</div>
        <div class="tools-row">
          <div class="tool-pill"><span class="tool-emoji">💻</span> WordPress / Elementor</div>
          <div class="tool-pill"><span class="tool-emoji">🛍️</span> Shopify</div>
          <div class="tool-pill"><span class="tool-emoji">📜</span> HTML5 & CSS3</div>
          <div class="tool-pill"><span class="tool-emoji">⚡</span> Astro.js</div>
          <div class="tool-pill"><span class="tool-emoji">🎨</span> Figma</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ SECTION 5 — CTA ═══════ -->
  <section class="about-cta">
    <div>
      <h2 class="cta-headline syne">Want to work<br><em>together?</em></h2>
      <p class="cta-sub">I'm currently accepting new projects and consulting opportunities.</p>
    </div>
    <div class="cta-btns">
      <a href="/contact" class="btn-main">Get in Touch</a>
      <a href="https://wa.me/8801740000000" class="btn-wa">Or WhatsApp Me</a>
    </div>
  </section>

  <style>
    /* ═══════════════ HERO ═══════════════ */
    .about-hero {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      position: relative;
      overflow: hidden;
      padding-top: var(--nav-h);
    }
    .about-hero-bg {
      position: absolute; inset: 0; pointer-events: none;
      background: radial-gradient(ellipse 60% 80% at 65% 50%, rgba(255, 77, 0, 0.055) 0%, transparent 65%);
    }
    .about-hero-grid {
      position: absolute; inset: 0; pointer-events: none;
      background-image: linear-gradient(rgba(255, 77, 0, 0.022) 1px, transparent 1px),
                        linear-gradient(90deg, rgba(255, 77, 0, 0.022) 1px, transparent 1px);
      background-size: 64px 64px;
    }

    .about-hero-photo {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 60px 40px 60px 7%;
    }
    .photo-frame { position: relative; width: 100%; max-width: 400px; }
    .photo-frame::before {
      content: ''; position: absolute; top: -20px; left: -20px; width: 55%; height: 55%;
      border-top: 2px solid var(--orange); border-left: 2px solid var(--orange); opacity: 0.6; z-index: 0;
    }
    .photo-frame::after {
      content: ''; position: absolute; bottom: -20px; right: -20px; width: 40%; height: 40%;
      border-bottom: 2px solid var(--orange); border-right: 2px solid var(--orange); opacity: 0.35; z-index: 0;
    }
    .photo-main { position: relative; z-index: 1; width: 100%; object-fit: cover; filter: grayscale(8%); display: block; }
    .photo-accent-bar { position: absolute; left: -12px; top: 15%; width: 4px; height: 40%; background: var(--orange); z-index: 2; }
    
    .photo-quote-badge {
      position: absolute; bottom: 24px; left: -24px; right: 24px;
      background: rgba(12, 12, 12, 0.92); backdrop-filter: blur(12px);
      border: 1px solid var(--border-o); border-left: 3px solid var(--orange); padding: 16px 20px; z-index: 3;
    }
    .quote-text { font-family: 'Syne', sans-serif; font-size: 0.85rem; font-weight: 600; color: var(--cream); line-height: 1.5; font-style: italic; }
    .quote-attr { font-size: 0.62rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--orange); margin-top: 6px; font-weight: 600; }

    .about-hero-content { display: flex; flex-direction: column; justify-content: center; padding: 60px 7% 60px 48px; position: relative; z-index: 2; }
    .about-hero-headline { font-size: clamp(2.2rem, 3.8vw, 3.8rem); font-weight: 800; letter-spacing: -0.03em; line-height: 1.06; color: var(--cream); margin-bottom: 1rem; }
    .about-hero-headline em { font-style: italic; color: var(--orange); }
    .about-hero-sub { font-size: 1rem; font-weight: 300; line-height: 1.85; color: var(--muted); max-width: 460px; margin-bottom: 2.4rem; }
    
    .hero-pills { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 2.8rem; }
    .pill { font-size: 0.7rem; font-weight: 500; padding: 7px 14px; border: 1px solid var(--border); color: var(--text); border-radius: 2px; }
    .pill.highlight { background: var(--orange-dim); border-color: var(--border-o); color: var(--orange); }

    .role-card { display: flex; align-items: center; gap: 14px; background: var(--surface); border: 1px solid var(--border); padding: 14px 18px; max-width: 380px; }
    .role-dot { width: 8px; height: 8px; border-radius: 50%; background: #22C55E; }
    .role-text { font-size: 0.82rem; font-weight: 500; color: var(--cream); }
    .role-sub { font-size: 0.7rem; color: var(--muted); margin-top: 2px; }

    /* ═══════════════ STORY ═══════════════ */
    .story-section { background: var(--dark2); }
    .story-wrap { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }
    .story-chapters { display: flex; flex-direction: column; }
    .chapter { padding: 2rem 0 2rem 2rem; border-left: 1px solid var(--border); position: relative; }
    .chapter::before { content: ''; position: absolute; left: -5px; top: 2rem; width: 9px; height: 9px; border-radius: 50%; background: var(--muted); border: 2px solid var(--dark2); }
    .chapter:hover::before { background: var(--orange); }
    .chapter-num { font-size: 0.58rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--orange); font-weight: 600; margin-bottom: 6px; }
    .chapter-title { font-family: 'Syne', sans-serif; font-size: 1.1rem; font-weight: 700; color: var(--cream); margin-bottom: 10px; }
    .chapter-body { font-size: 0.9rem; font-weight: 300; line-height: 1.85; color: var(--muted); }

    .story-visual { position: sticky; top: calc(var(--nav-h) + 40px); }
    .story-photo-wrap { position: relative; }
    .story-photo-wrap img { width: 100%; filter: grayscale(10%); transition: 0.4s; }
    .story-photo-wrap:hover img { filter: grayscale(0%); }
    .story-photo-label { position: absolute; bottom: 0; left: 0; right: 0; background: linear-gradient(transparent, rgba(12,12,12,0.95)); padding: 40px 20px 20px; }
    .story-photo-label-text { font-family: 'Syne', sans-serif; font-size: 0.75rem; font-weight: 700; color: var(--cream); text-transform: uppercase; }
    .story-photo-label-sub { font-size: 0.68rem; color: rgba(240,235,225,0.6); margin-top: 3px; }

    /* ═══════════════ EXPERIENCE ═══════════════ */
    .exp-grid { display: flex; flex-direction: column; }
    .exp-item { display: grid; grid-template-columns: 200px 1fr; gap: 2rem; padding: 2.5rem 0; border-bottom: 1px solid var(--border); position: relative; }
    .exp-item::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 2px; background: var(--orange); transform: scaleY(0); transition: 0.4s; }
    .exp-item:hover::before { transform: scaleY(1); }
    .exp-meta { padding-left: 1.5rem; }
    .exp-period { font-size: 0.68rem; font-weight: 600; color: var(--orange); text-transform: uppercase; margin-bottom: 6px; }
    .exp-company { font-family: 'Syne', sans-serif; font-size: 0.95rem; font-weight: 700; color: var(--cream); }
    .exp-role { font-family: 'Syne', sans-serif; font-size: 1.1rem; font-weight: 700; color: var(--cream); margin-bottom: 10px; }
    .exp-desc { font-size: 0.88rem; font-weight: 300; line-height: 1.8; color: var(--muted); margin-bottom: 12px; }
    .exp-tags { display: flex; flex-wrap: wrap; gap: 6px; }
    .exp-tag { font-size: 0.6rem; font-weight: 600; padding: 3px 9px; border: 1px solid var(--border); color: var(--muted); text-transform: uppercase; }

    /* ═══════════════ TOOLS ═══════════════ */
    .tools-section { background: var(--dark2); }
    .tools-intro { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: end; margin-bottom: 56px; }
    .tools-headline { font-size: clamp(2rem, 3.5vw, 3rem); font-weight: 800; color: var(--cream); }
    .tools-headline em { font-style: italic; color: var(--orange); }
    .tools-text { font-size: 0.9rem; color: var(--muted); line-height: 1.85; }
    .tools-categories { display: flex; flex-direction: column; gap: 2.5rem; }
    .tool-cat-label { font-size: 0.6rem; font-weight: 600; letter-spacing: 0.22em; text-transform: uppercase; color: var(--orange); margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
    .tool-cat-label::after { content: ''; flex: 1; height: 1px; background: var(--border); }
    .tools-row { display: flex; flex-wrap: wrap; gap: 8px; }
    .tool-pill { display: flex; align-items: center; gap: 8px; background: var(--surface); border: 1px solid var(--border); padding: 9px 14px; border-radius: 6px; font-size: 0.8rem; color: var(--text); transition: 0.25s; }
    .tool-pill:hover { border-color: var(--orange); color: var(--cream); transform: translateY(-2px); }

    /* ═══════════════ CTA ═══════════════ */
    .about-cta { background: var(--dark2); border-top: 1px solid var(--border); display: grid; grid-template-columns: 1fr auto; gap: 3rem; align-items: center; }
    .cta-headline { font-size: clamp(1.8rem, 3vw, 2.8rem); font-weight: 800; color: var(--cream); }
    .cta-headline em { font-style: italic; color: var(--orange); }
    .cta-sub { color: var(--muted); margin-top: 0.75rem; }
    .cta-btns { display: flex; flex-direction: column; gap: 10px; align-items: flex-end; }
    .btn-main { background: var(--orange); color: #fff; padding: 1.1rem 2.4rem; font-weight: 600; text-transform: uppercase; transition: 0.3s; }
    .btn-wa { font-size: 0.72rem; color: var(--muted); text-transform: uppercase; }

    /* ═══════════════ RESPONSIVE ═══════════════ */
    @media (max-width: 1024px) {
      .about-hero { grid-template-columns: 1fr; }
      .about-hero-photo { order: -1; padding-top: calc(var(--nav-h) + 20px); }
      .about-hero-content { padding: 40px 7%; }
      .story-wrap { grid-template-columns: 1fr; }
      .story-visual { position: static; }
      .exp-item { grid-template-columns: 1fr; gap: 0.5rem; }
      .exp-meta { padding-left: 0; border-left: 2px solid var(--orange); padding-left: 1rem; }
      .tools-intro { grid-template-columns: 1fr; }
      .about-cta { grid-template-columns: 1fr; text-align: center; }
      .cta-btns { align-items: center; }
    }
  </style>
</Layout>
