---
import Layout from '../../layouts/Layout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';

const reader = createReader(process.cwd(), keystaticConfig);
const projects = await reader.collections.portfolio.all();

// Sort by date descending
const sortedProjects = projects.sort((a, b) => 
  new Date(b.entry.date).getTime() - new Date(a.entry.date).getTime()
);
---

<Layout title="Portfolio — Imam Hasan Tahim | Digital Marketer & Web Developer">
  <!-- ══════════════ HERO ══════════════ -->
  <section class="portfolio-hero">
    <div class="hero-grid"></div>
    <div class="hero-orb"></div>
    <div class="hero-pre">My Work &mdash; ihtahim.com</div>
    <h1 class="hero-h1 syne">
      Recent projects<br>
      <em>&amp; results.</em>
    </h1>
    <p class="hero-sub">
      A collection of my work in <strong>performance marketing, web development, and digital strategy</strong>. 
      Every project is a blend of technical precision and creative strategy.
    </p>
  </section>

  <!-- ══════════════ PROJECTS GRID ══════════════ -->
  <section class="projects-section">
    <div class="projects-grid">
      {sortedProjects.map((project, index) => (
        <a href={`/portfolio/${project.slug}`} class={`project-card reveal visible d${(index % 3) + 1}`}>
          <div class="project-image">
            <img src={project.entry.image || '/images/project_placeholder.png'} alt={project.entry.title} />
            <div class="project-overlay">
              <span class="project-view-btn">View Details →</span>
            </div>
          </div>
          <div class="project-info">
            <div class="project-meta">
              <span class="project-cat">{project.entry.category}</span>
              <span class="project-date">{new Date(project.entry.date).getFullYear()}</span>
            </div>
            <h3 class="project-title syne">{project.entry.title}</h3>
            <p class="project-desc">{project.entry.description}</p>
          </div>
        </a>
      ))}

      {sortedProjects.length === 0 && (
        <div class="empty-state">
          <p>No projects found. Check back later!</p>
        </div>
      )}
    </div>
  </section>

  <style>
    .portfolio-hero {
      padding: calc(var(--nav-h) + 80px) 7% 80px;
      position: relative;
      overflow: hidden;
      min-height: 40vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .hero-grid {
      position: absolute; inset: 0; pointer-events: none;
      background-image: linear-gradient(rgba(255,77,0,0.022) 1px, transparent 1px),
                        linear-gradient(90deg, rgba(255,77,0,0.022) 1px, transparent 1px);
      background-size: 64px 64px;
    }
    .hero-orb {
      position: absolute; top: -20%; right: 5%; width: 500px; height: 500px;
      border-radius: 50%; background: radial-gradient(circle, rgba(255,77,0,0.065) 0%, transparent 65%);
    }
    .hero-h1 { font-size: clamp(2.5rem, 5vw, 5rem); font-weight: 800; color: var(--cream); margin-bottom: 1.5rem; }
    .hero-h1 em { color: var(--orange); font-style: italic; }
    .hero-sub { font-size: 1rem; color: var(--muted); max-width: 520px; line-height: 1.85; }

    .projects-section { padding: 0 7% 120px; }
    .projects-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 3rem; }
    
    .project-card { display: flex; flex-direction: column; text-decoration: none; transition: 0.4s; }
    .project-image { position: relative; overflow: hidden; background: var(--surface); aspect-ratio: 16/10; border: 1px solid var(--border); }
    .project-image img { width: 100%; height: 100%; object-fit: cover; transition: 0.6s var(--ease); }
    .project-overlay { position: absolute; inset: 0; background: rgba(12, 12, 12, 0.6); display: flex; align-items: center; justify-content: center; opacity: 0; transition: 0.4s; backdrop-filter: blur(4px); }
    .project-view-btn { padding: 12px 24px; background: var(--orange); color: #fff; font-weight: 600; text-transform: uppercase; font-size: 0.75rem; transform: translateY(10px); transition: 0.4s; }
    
    .project-card:hover .project-image img { transform: scale(1.05); }
    .project-card:hover .project-overlay { opacity: 1; }
    .project-card:hover .project-view-btn { transform: translateY(0); }

    .project-info { padding: 1.5rem 0; }
    .project-meta { display: flex; gap: 1rem; margin-bottom: 0.75rem; }
    .project-cat { font-size: 0.65rem; font-weight: 600; text-transform: uppercase; color: var(--orange); letter-spacing: 0.15em; }
    .project-date { font-size: 0.65rem; font-weight: 500; color: var(--muted); }
    .project-title { font-size: 1.5rem; font-weight: 700; color: var(--cream); margin-bottom: 0.75rem; transition: 0.3s; }
    .project-card:hover .project-title { color: var(--orange); }
    .project-desc { font-size: 0.9rem; color: var(--muted); line-height: 1.6; }

    .empty-state { grid-column: 1 / -1; text-align: center; padding: 100px 0; color: var(--muted); border: 1px dashed var(--border); }

    @media (max-width: 768px) {
      .projects-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    }
  </style>
</Layout>
