---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// Fetch all blog posts from the Keystatic collection
const posts = await getCollection('posts');

// Sort by date descending
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Blog | Portfolio">
  <section class="py-20 px-4 max-w-4xl mx-auto">
    <div class="text-center mb-16 animate-on-scroll">
      <h1 class="text-5xl font-syne font-bold mb-6">Thoughts & <span class="text-burntorange">Articles</span></h1>
      <p class="text-lg opacity-80">
        Insights on web development, performance optimization, and modern design.
      </p>
    </div>

    {sortedPosts.length === 0 ? (
      <div class="text-center py-10 opacity-70">
        <p>No blog posts found. Head over to <a href="/keystatic" class="text-burntorange underline">/keystatic</a> to create your first post!</p>
      </div>
    ) : (
      <div class="space-y-8">
        {sortedPosts.map((post, index) => (
          <article class="group relative block p-8 border border-charcoal/10 dark:border-offwhite/10 rounded-3xl hover:border-burntorange transition-colors animate-on-scroll" style={`transition-delay: ${index * 100}ms;`}>
            <div class="flex items-center gap-4 text-sm font-medium opacity-60 mb-4">
              <time datetime={post.data.date.toISOString()}>{post.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</time>
              <span>&bull;</span>
              <span>{post.data.readTime}</span>
            </div>
            <h2 class="text-3xl font-syne font-bold mb-4 group-hover:text-burntorange transition-colors">
              <a href={`/blog/${post.id}`}>
                <span class="absolute inset-0"></span>
                {post.data.title}
              </a>
            </h2>
            <p class="opacity-80 leading-relaxed mb-6">
              {post.data.description || 'Click to read more...'}
            </p>
            <span class="inline-flex items-center text-burntorange font-semibold group-hover:translate-x-2 transition-transform">
              Read Article 
              <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
            </span>
          </article>
        ))}
      </div>
    )}
  </section>
</Layout>
