---
import Layout from '../../layouts/Layout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';

export async function getStaticPaths() {
  const reader = createReader(process.cwd(), keystaticConfig);
  const posts = await reader.collections.posts.all();
  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const reader = createReader(process.cwd(), keystaticConfig);
const post = await reader.collections.posts.read(slug);

if (!post) {
  return Astro.redirect('/404');
}

const { content } = await post.content();
---

<Layout title={`${post.title} — Blog | Imam Hasan Tahim`}>
  <article class="post-page">
    <header class="post-header">
      <div class="hero-grid"></div>
      <div class="container narrow">
        <a href="/blog" class="back-link">← Back to Insights</a>
        <div class="post-meta">
          <time>{new Date(post.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</time>
          <span class="sep">·</span>
          <span>{post.readTime}</span>
        </div>
        <h1 class="post-title syne">{post.title}</h1>
        <p class="post-description">{post.description}</p>
      </div>
    </header>

    <div class="post-content">
      <div class="container narrow">
        {post.image && (
          <div class="featured-image">
            <img src={post.image} alt={post.title} />
          </div>
        )}
        <div class="rich-text">
          <p>Full blog content will be rendered here...</p>
        </div>
      </div>
    </div>
  </article>

  <style>
    .post-header { padding: calc(var(--nav-h) + 60px) 7% 60px; position: relative; background: var(--dark2); border-bottom: 1px solid var(--border); }
    .hero-grid { position: absolute; inset: 0; pointer-events: none; opacity: 0.3; background-image: linear-gradient(rgba(255,77,0,0.022) 1px, transparent 1px), linear-gradient(90deg, rgba(255,77,0,0.022) 1px, transparent 1px); background-size: 64px 64px; }
    .container { max-width: 1200px; margin: 0 auto; position: relative; z-index: 1; }
    .container.narrow { max-width: 800px; }
    
    .back-link { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; color: var(--orange); text-decoration: none; display: inline-block; margin-bottom: 2rem; }
    .post-meta { display: flex; align-items: center; gap: 10px; margin-bottom: 1rem; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; color: var(--muted); letter-spacing: 0.1em; }
    .sep { color: var(--orange); }
    .post-title { font-size: clamp(2.2rem, 4vw, 3.5rem); font-weight: 800; color: var(--cream); line-height: 1.15; margin-bottom: 1.5rem; }
    .post-description { font-size: 1.1rem; color: var(--muted); line-height: 1.7; }

    .post-content { padding: 60px 7% 120px; }
    .featured-image { margin-bottom: 3rem; border: 1px solid var(--border); }
    .featured-image img { width: 100%; display: block; }
    
    .rich-text { font-size: 1.1rem; line-height: 1.9; color: var(--text); }
  </style>
</Layout>
