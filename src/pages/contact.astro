---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | Imam Hasan Tahim">
<!-- HERO -->
<section class="hero">
  <div class="hero-grid"></div>
  <div class="hero-orb"></div>

  <div class="hero-pre">Get In Touch &mdash; ihtahim.com</div>

  <h1 class="hero-h1">
    Let&#39;s build<br>
    something<br>
    <em>great</em> <span class="outline">together.</span>
  </h1>

  <p class="hero-sub">
    Have a project in mind or need a <strong>free 15-minute strategy call</strong>?
    Fill out the form or reach out directly &#8212; I respond within an hour on most days.
  </p>

  <div class="avail-strip">
    <div class="avail-item">
      <div class="avail-dot"></div>
      Available for freelance projects
    </div>
    <div class="avail-sep"></div>
    <div class="avail-item">
      <div class="avail-dot"></div>
      Open to full-time roles
    </div>
    <div class="avail-sep"></div>
    <div class="avail-item">&#128205; Dhaka, Bangladesh</div>
  </div>
</section>

<!-- MAIN CONTACT LAYOUT -->
<section class="contact-section">

  <!-- LEFT — Info -->
  <div class="contact-info reveal">
    <div class="eyebrow">Direct Contact</div>
    <h2 class="info-headline">
      No contact forms<br>needed &#8212; <em>just reach out.</em>
    </h2>
    <p class="info-body">
      I believe the best projects start with a real conversation.
      Reach out on <strong>WhatsApp for the fastest response</strong> &#8212;
      or use any channel below. I&#39;m equally reachable on email,
      LinkedIn, and Facebook.
    </p>

    <div class="contact-cards">

      <a href="https://wa.me/8801673539272?text=Hi%20Tahim%2C%20I%27d%20like%20to%20discuss%20a%20project."
         target="_blank" class="contact-card">
        <div class="cc-icon">&#128172;</div>
        <div>
          <div class="cc-label">WhatsApp (Fastest)</div>
          <div class="cc-value">+880 167 353 9272</div>
        </div>
        <div class="cc-arr">&#8594;</div>
      </a>

      <a href="mailto:imamhasantahim@gmail.com?subject=Project%20Inquiry"
         class="contact-card">
        <div class="cc-icon">&#9993;&#65039;</div>
        <div>
          <div class="cc-label">Email</div>
          <div class="cc-value">imamhasantahim@gmail.com</div>
        </div>
        <div class="cc-arr">&#8594;</div>
      </a>

      <a href="https://www.linkedin.com/in/i-h-tahim/"
         target="_blank" class="contact-card">
        <div class="cc-icon">&#128188;</div>
        <div>
          <div class="cc-label">LinkedIn</div>
          <div class="cc-value">linkedin.com/in/i-h-tahim</div>
        </div>
        <div class="cc-arr">&#8594;</div>
      </a>

      <a href="https://www.facebook.com/tahim022"
         target="_blank" class="contact-card">
        <div class="cc-icon">&#128100;</div>
        <div>
          <div class="cc-label">Facebook</div>
          <div class="cc-value">facebook.com/tahim022</div>
        </div>
        <div class="cc-arr">&#8594;</div>
      </a>

    </div>

    <div class="social-row">
      <a href="https://www.linkedin.com/in/i-h-tahim/" target="_blank" class="soc-btn">
        <span>in</span> LinkedIn
      </a>
      <a href="https://www.facebook.com/tahim022" target="_blank" class="soc-btn">
        <span>f</span> Facebook
      </a>
      <a href="https://instagram.com/ih_tahim" target="_blank" class="soc-btn">
        <span>ig</span> Instagram
      </a>
    </div>

    <div class="response-card">
      <div class="rc-icon">&#9889;</div>
      <div>
        <div class="rc-text">Typically responds within 1 hour</div>
        <div class="rc-sub">Available Mon &mdash; Sat &middot; 9am &mdash; 10pm (BST)</div>
      </div>
    </div>
  </div>

  <!-- RIGHT — Form -->
  <div class="contact-form-wrap reveal d2">

    <div id="form-container">
      <div class="form-head">
        <div class="form-title">Send a Message</div>
        <div class="form-sub">I&#39;ll get back to you within 24 hours &#8212; usually much faster.</div>
      </div>

      <form id="contactForm" action="https://api.web3forms.com/submit" method="POST">

        <!-- Web3Forms access key -->
        <input type="hidden" name="access_key" value="5aba4a1d-a10f-4e22-a0de-2edee4600bf3"/>

        <!-- Redirect (optional — keeps user on page) -->
        <input type="hidden" name="redirect" value="false"/>

        <!-- Subject line for email -->
        <input type="hidden" name="subject" value="New Contact Form Submission — ihtahim.com"/>

        <!-- From name label -->
        <input type="hidden" name="from_name" value="ihtahim.com Contact Form"/>

        <!-- Honeypot anti-spam -->
        <input type="checkbox" name="botcheck" class="hp" style="display:none"/>

        <div class="form-grid">

          <div class="field">
            <label for="fname">First Name *</label>
            <input type="text" id="fname" name="first_name"
                   placeholder="Rahim" required autocomplete="given-name"/>
          </div>

          <div class="field">
            <label for="lname">Last Name</label>
            <input type="text" id="lname" name="last_name"
                   placeholder="Hossain" autocomplete="family-name"/>
          </div>

          <div class="field full">
            <label for="email">Email Address *</label>
            <input type="email" id="email" name="email"
                   placeholder="you@example.com" required autocomplete="email"/>
          </div>

          <div class="field full">
            <label for="phone">Phone / WhatsApp</label>
            <input type="tel" id="phone" name="phone"
                   placeholder="+880 1X XX XXX XXX" autocomplete="tel"/>
          </div>

          <div class="field full">
            <label for="service">Service Interested In *</label>
            <div class="select-wrap">
              <select id="service" name="service" required>
                <option value="" disabled selected>Select a service&#8230;</option>
                <option value="Funnel Building">Conversion-Optimised Funnel Building</option>
                <option value="Facebook & Google Ads">Facebook &amp; Google Ads</option>
                <option value="E-commerce / Shopify">E-commerce Development &amp; Growth (Shopify)</option>
                <option value="WordPress Development">Service Business Lead Gen (WordPress)</option>
                <option value="Technical SEO">Technical SEO &amp; Performance Auditing</option>
                <option value="Advanced Tracking">Advanced Tracking &amp; Data Analytics</option>
                <option value="Content Strategy">Content &amp; Digital Strategy Consulting</option>
                <option value="Other">Other / Not sure yet</option>
              </select>
            </div>
          </div>

          <div class="field full">
            <label for="budget">Estimated Budget (Optional)</label>
            <div class="select-wrap">
              <select id="budget" name="budget">
                <option value="" disabled selected>Select a range&#8230;</option>
                <option value="Under $200">Under $200</option>
                <option value="$200 - $500">$200 &mdash; $500</option>
                <option value="$500 - $1000">$500 &mdash; $1,000</option>
                <option value="$1000 - $2500">$1,000 &mdash; $2,500</option>
                <option value="$2500+">$2,500+</option>
                <option value="Let's discuss">Let&#39;s discuss</option>
              </select>
            </div>
          </div>

          <div class="field full">
            <label for="message">Your Message *</label>
            <textarea id="message" name="message"
                      placeholder="Tell me about your project, goals, or questions&#8230;"
                      required maxlength="1000" oninput="updateCount(this)"></textarea>
            <div class="field-footer">
              <span></span>
              <span class="char-count" id="charCount">0 / 1000</span>
            </div>
          </div>

          <div class="field full">
            <label for="source">How did you find me? (Optional)</label>
            <div class="select-wrap">
              <select id="source" name="source">
                <option value="" disabled selected>Select&#8230;</option>
                <option value="Google Search">Google Search</option>
                <option value="Facebook">Facebook</option>
                <option value="LinkedIn">LinkedIn</option>
                <option value="Instagram">Instagram</option>
                <option value="Referral">Referral from someone</option>
                <option value="NFC Card">NFC Business Card</option>
                <option value="Other">Other</option>
              </select>
            </div>
          </div>

        </div>

        <button type="submit" class="submit-btn" id="submitBtn">
          <span class="btn-text">&#128172; Send Message &rarr;</span>
          <div class="btn-spinner"></div>
        </button>

        <p class="form-note">
          By submitting you agree your details will be used to respond to your inquiry.
          I will never share your information with third parties.
        </p>

      </form>
    </div>

    <!-- Success state -->
    <div class="success-state" id="successState">
      <div class="success-icon">&#10003;</div>
      <div class="success-title">Message Sent!</div>
      <p class="success-msg">
        Thanks for reaching out. I&#39;ve received your message and will
        get back to you within 24 hours &#8212; usually much sooner.
        <br/><br/>
        In the meantime, feel free to connect on
        <a href="https://wa.me/8801673539272" style="color:var(--o)" target="_blank">WhatsApp</a>
        for a faster reply.
      </p>
      <button class="success-back" onclick="resetForm()">
        &#8592; Send Another Message
      </button>
    </div>

  </div>
</section>

<!-- FAQ -->
<section class="faq-section">
  <div class="eyebrow reveal" style="margin-bottom:1rem">Quick Answers</div>
  <h2 class="reveal d1" style="font-family:'Syne',sans-serif;font-size:clamp(1.8rem,3vw,2.8rem);font-weight:800;letter-spacing:-0.02em;color:var(--cream);line-height:1.1;">
    Common questions<br><em style="font-style:italic;color:var(--o)">before you reach out.</em>
  </h2>

  <div class="faq-grid">
    <div class="faq-item reveal d1">
      <div class="faq-q">Do you show pricing on your site?</div>
      <p class="faq-a">No &#8212; every project is different. <strong>Contact me with your requirements</strong> and I&#39;ll give you a clear, honest proposal within 24 hours. No hidden fees.</p>
    </div>
    <div class="faq-item reveal d2">
      <div class="faq-q">How quickly can you start?</div>
      <p class="faq-a">Usually within <strong>1&ndash;3 business days</strong> of agreeing on scope. I&#39;ll give you a clear timeline during our discovery call.</p>
    </div>
    <div class="faq-item reveal d3">
      <div class="faq-q">Do you work with international clients?</div>
      <p class="faq-a">Absolutely. I currently manage digital marketing for a <strong>company in Canberra, Australia</strong> remotely. Time zones are no barrier.</p>
    </div>
    <div class="faq-item reveal d1">
      <div class="faq-q">What&#39;s the best way to contact you?</div>
      <p class="faq-a"><strong>WhatsApp</strong> is the fastest &#8212; I typically respond within an hour. Email works great too for more detailed inquiries.</p>
    </div>
    <div class="faq-item reveal d2">
      <div class="faq-q">Do you offer a free consultation?</div>
      <p class="faq-a">Yes &#8212; I offer a <strong>free 15-minute discovery call</strong> where I&#39;ll review your current setup and identify your biggest growth opportunity. No obligation.</p>
    </div>
    <div class="faq-item reveal d3">
      <div class="faq-q">Can you handle both marketing and development?</div>
      <p class="faq-a">That&#39;s exactly my edge. I build the landing page <em>and</em> run the ads on it. <strong>No coordination overhead</strong> between a developer and a marketer.</p>
    </div>
  </div>
</section>

<!-- FOOTER -->
</Layout>
