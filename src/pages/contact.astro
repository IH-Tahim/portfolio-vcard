---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | Portfolio">
  <section class="py-20 px-4 max-w-3xl mx-auto">
    <div class="text-center mb-12 animate-on-scroll">
      <h1 class="text-5xl font-syne font-bold mb-6">Get In <span class="text-burntorange">Touch</span></h1>
      <p class="text-lg opacity-80">
        Have a project in mind? Let's talk about it. Fill out the form below and I'll get back to you shortly.
      </p>
    </div>

    <div class="bg-charcoal/5 dark:bg-offwhite/5 p-8 md:p-12 rounded-3xl animate-on-scroll" style="transition-delay: 200ms;">
      <!-- Web3Forms integration - replace YOUR_ACCESS_KEY_HERE with actual key -->
      <form action="https://api.web3forms.com/submit" method="POST" class="space-y-6">
        <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE" />
        <input type="hidden" name="subject" value="New Contact from Portfolio Website" />
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <label for="name" class="block font-medium">Name</label>
            <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-xl bg-white dark:bg-charcoal border border-charcoal/10 dark:border-offwhite/10 focus:outline-none focus:border-burntorange transition-colors" placeholder="John Doe" />
          </div>
          <div class="space-y-2">
            <label for="email" class="block font-medium">Email</label>
            <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-xl bg-white dark:bg-charcoal border border-charcoal/10 dark:border-offwhite/10 focus:outline-none focus:border-burntorange transition-colors" placeholder="john@example.com" />
          </div>
        </div>
        
        <div class="space-y-2">
          <label for="message" class="block font-medium">Message</label>
          <textarea id="message" name="message" rows="5" required class="w-full px-4 py-3 rounded-xl bg-white dark:bg-charcoal border border-charcoal/10 dark:border-offwhite/10 focus:outline-none focus:border-burntorange transition-colors" placeholder="Tell me about your project..."></textarea>
        </div>
        
        <button type="submit" class="w-full py-4 bg-burntorange text-white font-semibold rounded-xl hover:bg-burntorange/90 transition-colors">
          Send Message
        </button>
      </form>
    </div>
  </section>
</Layout>
