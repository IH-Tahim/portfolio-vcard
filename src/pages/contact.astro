---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Imam Hasan Tahim | Digital Marketer & Web Developer Dhaka">
  <!-- HERO -->
  <section class="hero">
    <div class="hero-grid"></div>
    <div class="hero-orb"></div>

    <div class="hero-pre">Get In Touch &mdash; ihtahim.com</div>

    <h1 class="hero-h1 syne">
      Let&#39;s build<br>
      something<br>
      <em>great</em> <span class="outline">together.</span>
    </h1>

    <p class="hero-sub">
      Have a project in mind or need a <strong>free 15-minute strategy call</strong>?
      Fill out the form or reach out directly &#8212; I respond within an hour on most days.
    </p>

    <div class="avail-strip">
      <div class="avail-item">
        <div class="avail-dot"></div>
        Available for freelance projects
      </div>
      <div class="avail-sep"></div>
      <div class="avail-item">
        <div class="avail-dot"></div>
        Open to full-time roles
      </div>
      <div class="avail-sep"></div>
      <div class="avail-item">&#128205; Dhaka, Bangladesh</div>
    </div>
  </section>

  <!-- MAIN CONTACT LAYOUT -->
  <section class="contact-section">
    <!-- LEFT — Info -->
    <div class="contact-info reveal visible">
      <div class="eyebrow">Direct Contact</div>
      <h2 class="info-headline syne">
        No contact forms<br>needed &#8212; <em>just reach out.</em>
      </h2>
      <p class="info-body">
        I believe the best projects start with a real conversation.
        Reach out on <strong>WhatsApp for the fastest response</strong> &#8212;
        or use any channel below.
      </p>

      <div class="contact-cards">
        <a href="https://wa.me/8801673539272" target="_blank" class="contact-card">
          <div class="cc-icon">💬</div>
          <div>
            <div class="cc-label">WhatsApp (Fastest)</div>
            <div class="cc-value">+880 167 353 9272</div>
          </div>
          <div class="cc-arr">→</div>
        </a>
        <a href="mailto:imamhasantahim@gmail.com" class="contact-card">
          <div class="cc-icon">✉️</div>
          <div>
            <div class="cc-label">Email</div>
            <div class="cc-value">imamhasantahim@gmail.com</div>
          </div>
          <div class="cc-arr">→</div>
        </a>
      </div>

      <div class="social-row">
        <a href="https://www.linkedin.com/in/i-h-tahim/" target="_blank" class="soc-btn"><span>in</span> LinkedIn</a>
        <a href="https://www.facebook.com/tahim022" target="_blank" class="soc-btn"><span>f</span> Facebook</a>
      </div>

      <div class="response-card">
        <div class="rc-icon">⚡</div>
        <div>
          <div class="rc-text">Typically responds within 1 hour</div>
          <div class="rc-sub">Available Mon — Sat · 9am — 10pm (BST)</div>
        </div>
      </div>
    </div>

    <!-- RIGHT — Form -->
    <div class="contact-form-wrap reveal visible d2">
      <div id="form-container">
        <div class="form-head">
          <div class="form-title syne">Send a Message</div>
          <div class="form-sub">I'll get back to you within 24 hours — usually much faster.</div>
        </div>

        <form id="contactForm">
          <div class="form-grid">
            <div class="field">
              <label for="fname">First Name *</label>
              <input type="text" id="fname" name="first_name" placeholder="Rahim" required />
            </div>
            <div class="field">
              <label for="lname">Last Name</label>
              <input type="text" id="lname" name="last_name" placeholder="Hossain" />
            </div>
            <div class="field full">
              <label for="email">Email Address *</label>
              <input type="email" id="email" name="email" placeholder="you@example.com" required />
            </div>
            <div class="field full">
              <label for="message">Your Message *</label>
              <textarea id="message" name="message" placeholder="Tell me about your project..." required></textarea>
            </div>
          </div>
          <button type="submit" class="submit-btn" id="submitBtn">
            <span class="btn-text">Send Message →</span>
          </button>
        </form>
      </div>
    </div>
  </section>

  <style>
    /* ════════════════ HERO ════════════════ */
    .hero {
      min-height: 55vh; display: flex; flex-direction: column;
      justify-content: center; position: relative; overflow: hidden;
      padding: calc(var(--nav-h) + 80px) 7% 80px;
    }
    .hero-grid {
      position: absolute; inset: 0; pointer-events: none;
      background-image: linear-gradient(rgba(255,77,0,.022) 1px, transparent 1px),
                        linear-gradient(90deg, rgba(255,77,0,.022) 1px, transparent 1px);
      background-size: 64px 64px;
    }
    .hero-orb { position: absolute; top: -20%; right: 5%; width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(255,77,0,0.065) 0%, transparent 65%); }
    .hero-h1 { font-size: clamp(3rem, 7vw, 7rem); font-weight: 800; color: var(--cream); margin-bottom: 1.8rem; }
    .hero-h1 em { font-style: italic; color: var(--orange); }
    .hero-h1 .outline { -webkit-text-stroke: 1.5px var(--cream); color: transparent; }
    .hero-sub { font-size: 1rem; color: var(--muted); max-width: 520px; line-height: 1.85; }

    .avail-strip { display: flex; align-items: center; gap: 2rem; flex-wrap: wrap; margin-top: 2.5rem; }
    .avail-item { display: flex; align-items: center; gap: 8px; font-size: .8rem; font-weight: 500; color: var(--text); }
    .avail-dot { width: 8px; height: 8px; border-radius: 50%; background: #22C55E; box-shadow: 0 0 8px rgba(34,197,94,0.5); }
    .avail-sep { width: 1px; height: 20px; background: var(--border); }

    /* ════════════════ CONTACT ════════════════ */
    .contact-section { padding: 0 7% 120px; display: grid; grid-template-columns: 1fr 1.1fr; gap: 5rem; align-items: start; }
    .info-headline { font-size: clamp(1.8rem, 3vw, 2.6rem); font-weight: 800; color: var(--cream); margin: 1.5rem 0 1rem; }
    .info-headline em { color: var(--orange); font-style: italic; }
    .info-body { color: var(--muted); line-height: 1.9; margin-bottom: 2.5rem; }

    .contact-cards { display: flex; flex-direction: column; gap: 10px; margin-bottom: 2.5rem; }
    .contact-card { display: flex; align-items: center; gap: 14px; background: var(--surface); border: 1px solid var(--border); padding: 1rem 1.2rem; transition: 0.3s; }
    .contact-card:hover { border-color: var(--orange); background: var(--orange-dim); transform: translateX(6px); }
    .cc-icon { width: 38px; height: 38px; border-radius: 8px; background: var(--orange-dim); border: 1px solid var(--border-o); display: flex; align-items: center; justify-content: center; }
    .cc-label { font-size: .62rem; font-weight: 600; text-transform: uppercase; color: var(--muted); }
    .cc-value { font-size: .88rem; font-weight: 500; color: var(--cream); }
    .cc-arr { margin-left: auto; color: var(--muted); transition: 0.3s; }

    .social-row { display: flex; gap: 8px; }
    .soc-btn { flex: 1; padding: 12px 8px; background: var(--surface); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; gap: 8px; font-size: .72rem; font-weight: 600; color: var(--muted); text-transform: uppercase; transition: 0.3s; }
    .soc-btn:hover { border-color: var(--orange); color: var(--cream); transform: translateY(-2px); }

    .response-card { margin-top: 1.5rem; background: var(--surface2); border-left: 3px solid var(--orange); padding: 1.1rem 1.4rem; display: flex; align-items: center; gap: 12px; }
    .rc-text { font-size: .82rem; font-weight: 500; color: var(--cream); }
    .rc-sub { font-size: .7rem; color: var(--muted); }

    .contact-form-wrap { background: var(--surface); border: 1px solid var(--border); padding: 2.5rem; position: relative; }
    .contact-form-wrap::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--orange); }
    .form-title { font-size: 1.3rem; font-weight: 700; color: var(--cream); margin-bottom: 4px; }
    .form-sub { font-size: .82rem; color: var(--muted); margin-bottom: 2rem; }

    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .field.full { grid-column: 1/-1; }
    .field label { font-size: .62rem; font-weight: 600; text-transform: uppercase; color: var(--muted); margin-bottom: 6px; display: block; }
    .field input, .field textarea { background: var(--surface2); border: 1px solid var(--border); padding: 12px 14px; color: var(--cream); width: 100%; outline: none; transition: 0.25s; }
    .field input:focus, .field textarea:focus { border-color: var(--orange); box-shadow: 0 0 0 3px var(--orange-dim); }
    .field textarea { height: 110px; resize: none; }

    .submit-btn { width: 100%; padding: 1.1rem; margin-top: 1rem; background: var(--orange); color: #fff; border: none; font-weight: 600; text-transform: uppercase; cursor: pointer; transition: 0.3s; }
    .submit-btn:hover { background: #e64400; transform: translateY(-2px); box-shadow: 0 16px 40px rgba(255,77,0,0.35); }

    @media (max-width: 1024px) {
      .contact-section { grid-template-columns: 1fr; }
    }
  </style>
</Layout>
