---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Imam Hasan Tahim — Digital Marketer & Web Developer | Dhaka, Bangladesh">
  <!-- ═══════════════════ HERO ═══════════════════ -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-grid"></div>

    <div class="hero-left">
      <div class="eyebrow hero-eyebrow">
        Available for freelance &amp; full-time · Dhaka, Bangladesh
      </div>

      <h1 class="hero-name syne">Imam Hasan<br>Tahim</h1>

      <div class="hero-role">Digital Marketer<br>&amp; Web Developer</div>

      <p class="hero-desc">
        I help <strong>businesses grow online</strong> through data-driven
        paid advertising, conversion-focused web experiences, and
        strategic content — from Dhaka to the world.
      </p>

      <div class="hero-actions">
        <a href="/services" class="btn-hero-primary">See What I Do</a>
        <a href="/contact" class="btn-hero-secondary">
          Let's Talk
          <span class="arr">→</span>
        </a>
      </div>

      <div class="hero-stats">
        <div>
          <div class="stat-num">3<sup>+</sup></div>
          <div class="stat-label">Years experience</div>
        </div>
        <div>
          <div class="stat-num">12<sup>+</sup></div>
          <div class="stat-label">Happy clients</div>
        </div>
        <div>
          <div class="stat-num">6</div>
          <div class="stat-label">Core services</div>
        </div>
      </div>
    </div>

    <div class="hero-right">
      <div class="hero-photo">
        <img src="/images/hero_photo.png" alt="Imam Hasan Tahim"/>
      </div>

      <!-- Floating card 1 -->
      <div class="float-card float-card-1">
        <div class="fc-label">Status</div>
        <div class="fc-value"><span class="fc-dot"></span>Open to work</div>
      </div>

      <!-- Floating card 2 -->
      <div class="float-card float-card-2">
        <div class="fc-label">Current role</div>
        <div class="fc-value">IT Manager · Spotless4u</div>
      </div>
    </div>

    <div class="scroll-ind">
      <div class="scroll-line"></div>
      <div class="scroll-txt">Scroll</div>
    </div>
  </section>

  <!-- ═══════════════════ TICKER ═══════════════════ -->
  <div class="ticker-wrap" aria-hidden="true">
    <div class="ticker-track">
      <div class="ticker-item">Facebook Ads</div>
      <div class="ticker-item">Google Ads</div>
      <div class="ticker-item">SEO Strategy</div>
      <div class="ticker-item">Social Media Marketing</div>
      <div class="ticker-item">WordPress Development</div>
      <div class="ticker-item">Shopify Optimization</div>
      <div class="ticker-item">Landing Page Design</div>
      <div class="ticker-item">Content Marketing</div>
      <!-- Duplicate for seamless loop -->
      <div class="ticker-item">Facebook Ads</div>
      <div class="ticker-item">Google Ads</div>
      <div class="ticker-item">SEO Strategy</div>
      <div class="ticker-item">Social Media Marketing</div>
      <div class="ticker-item">WordPress Development</div>
      <div class="ticker-item">Shopify Optimization</div>
      <div class="ticker-item">Landing Page Design</div>
      <div class="ticker-item">Content Marketing</div>
    </div>
  </div>

  <!-- ═══════════════════ SERVICES ═══════════════════ -->
  <section class="services" id="services">
    <div class="services-intro reveal">
      <div>
        <div class="eyebrow" style="margin-bottom:1.2rem">What I Do</div>
        <h2 class="services-headline syne">
          Marketing that<br><em>actually works.</em>
        </h2>
      </div>
      <p class="services-text">
        From crafting high-converting ad campaigns to building fast, 
        beautiful websites — I deliver end-to-end digital solutions 
        that drive real, measurable results for your business.
      </p>
    </div>

    <div class="services-grid">
      <div class="service-card reveal reveal-delay-1">
        <span class="service-icon">📣</span>
        <div class="service-name">Facebook &amp; Instagram Ads</div>
        <p class="service-desc">
          Targeted Meta campaigns that put your brand in front of the right
          people. From audience research and creative strategy to full
          campaign management and ROAS optimization.
        </p>
        <span class="service-tag">Meta Ads · Retargeting · Pixel Setup</span>
      </div>

      <div class="service-card reveal reveal-delay-2">
        <span class="service-icon">🔍</span>
        <div class="service-name">Google Ads</div>
        <p class="service-desc">
          Search, Display, and Shopping campaigns engineered to capture
          high-intent buyers. Keyword strategy, ad copy, bidding — all
          tuned for maximum return on every taka spent.
        </p>
        <span class="service-tag">Search · Shopping · Performance Max</span>
      </div>

      <div class="service-card reveal reveal-delay-3">
        <span class="service-icon">📈</span>
        <div class="service-name">SEO &amp; Content Marketing</div>
        <p class="service-desc">
          Long-term organic growth through technical SEO, keyword research,
          and strategic content that ranks, builds authority, and drives
          qualified traffic month after month.
        </p>
        <span class="service-tag">On-page · Technical · Content Strategy</span>
      </div>

      <div class="service-card reveal reveal-delay-1">
        <span class="service-icon">📱</span>
        <div class="service-name">Social Media Marketing</div>
        <p class="service-desc">
          Brand storytelling across Facebook, Instagram, and LinkedIn.
          Content calendars, community management, and growth strategies
          tailored to your audience and goals.
        </p>
        <span class="service-tag">Content · Community · Analytics</span>
      </div>

      <div class="service-card reveal reveal-delay-2">
        <span class="service-icon">🛒</span>
        <div class="service-name">Shopify Optimization</div>
        <p class="service-desc">
          Boost your e-commerce store's performance — speed optimization,
          conversion rate improvements, theme customization, and app
          integration to maximize every visitor's value.
        </p>
        <span class="service-tag">CRO · Speed · UX Optimization</span>
      </div>

      <div class="service-card reveal reveal-delay-3">
        <span class="service-icon">💻</span>
        <div class="service-name">WordPress &amp; Landing Pages</div>
        <p class="service-desc">
          High-converting landing pages and full WordPress sites built
          with performance and design in mind. Clean code, fast load
          times, and built to turn visitors into customers.
        </p>
        <span class="service-tag">WordPress · HTML/CSS · Conversion Design</span>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ ABOUT STRIP ═══════════════════ -->
  <section id="about">
    <div class="about-strip">
      <div class="about-photo-wrap reveal">
        <img src="/images/about_photo.png" alt="Imam Hasan Tahim — Digital Marketer"/>
        <div class="about-exp-badge">
          <div class="about-exp-num">3<sup>+</sup></div>
          <div class="about-exp-label">Years of<br>Growth</div>
        </div>
      </div>

      <div class="about-content reveal reveal-delay-2">
        <div class="eyebrow" style="margin-bottom:1.5rem">A bit about me</div>
        <h2 class="about-headline">
          The mind behind the<br><em>digital strategy.</em>
        </h2>
        <p class="about-body">
          I'm Imam Hasan Tahim, a <strong>Digital Marketer and Web Developer</strong>
          dedicated to helping brands thrive in the digital age. I don't just run ads
          or build sites; I create systems that generate growth.
        </p>
        <div class="about-tags">
          <span class="about-tag">Strategy</span>
          <span class="about-tag">Paid Ads</span>
          <span class="about-tag">SEO</span>
          <span class="about-tag">Development</span>
          <span class="about-tag">Analytics</span>
        </div>
        <a href="/about" class="btn-cv">
          More About Me
          <span style="font-size:1.1rem">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ CTA BANNER ═══════════════════ -->
  <section class="cta-banner reveal">
    <div class="cta-content">
      <h2 class="cta-headline">Ready to scale your<br><em>business online?</em></h2>
      <p class="cta-sub">Let's build a strategy that actually converts your visitors into loyal customers.</p>
    </div>
    <div class="cta-actions">
      <a href="/contact" class="btn-cta-main">Start a Project</a>
      <a href="https://wa.me/8801740000000" class="btn-cta-wa">
        <span>💬</span> Or WhatsApp Me
      </a>
    </div>
  </section>

  <style>
    /* Hero section styles from original demo */
    .hero {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      position: relative;
      overflow: hidden;
    }
    .hero-bg {
      position: absolute; inset: 0; pointer-events: none;
      background: radial-gradient(ellipse 50% 70% at 70% 40%, rgba(255,77,0,0.055) 0%, transparent 65%),
                  radial-gradient(ellipse 30% 40% at 20% 80%, rgba(255,77,0,0.03) 0%, transparent 60%);
    }
    .hero-grid {
      position: absolute; inset: 0; pointer-events: none;
      background-image: linear-gradient(rgba(255,77,0,0.025) 1px, transparent 1px),
                        linear-gradient(90deg, rgba(255,77,0,0.025) 1px, transparent 1px);
      background-size: 64px 64px;
    }
    .hero-left {
      display: flex; flex-direction: column; justify-content: center;
      padding: calc(var(--nav-h) + 60px) 5% 80px 7%;
      position: relative; z-index: 2;
    }
    .hero-name { font-size: clamp(2.8rem, 4.5vw, 4.4rem); font-weight: 800; color: var(--cream); line-height: 1.04; margin-bottom: 0.25rem; }
    .hero-role { font-size: clamp(1.6rem, 2.8vw, 2.6rem); font-weight: 600; color: var(--orange); margin-bottom: 1.8rem; }
    .hero-desc { font-size: 1rem; color: var(--muted); max-width: 420px; margin-bottom: 2.8rem; line-height: 1.85; }
    .hero-actions { display: flex; gap: 1.5rem; flex-wrap: wrap; }
    .hero-stats { display: flex; gap: 2.5rem; margin-top: 3.5rem; padding-top: 2rem; border-top: 1px solid var(--border); }
    .stat-num { font-size: 2rem; font-weight: 800; color: var(--cream); line-height: 1; }
    .stat-num sup { color: var(--orange); }
    .stat-label { font-size: 0.63rem; color: var(--muted); margin-top: 4px; text-transform: uppercase; letter-spacing: 0.14em; }
    
    .btn-hero-primary { background: var(--orange); color: #fff; padding: 1rem 2.2rem; text-transform: uppercase; font-weight: 600; letter-spacing: 0.14em; transition: 0.3s; }
    .btn-hero-secondary { color: var(--text); display: flex; align-items: center; gap: 8px; text-transform: uppercase; font-weight: 500; letter-spacing: 0.12em; }
    .btn-hero-secondary .arr { width: 28px; height: 28px; border-radius: 50%; border: 1px solid var(--border-o); display: flex; align-items: center; justify-content: center; color: var(--orange); transition: 0.3s; }
    .btn-hero-secondary:hover .arr { background: var(--orange); color: #fff; transform: translateX(4px); }

    .hero-right { position: relative; display: flex; align-items: flex-end; justify-content: center; padding-top: var(--nav-h); }
    .hero-right::before {
      content: ''; position: absolute; bottom: 0; left: 50%; transform: translateX(-50%);
      width: 75%; height: 90%; background: linear-gradient(160deg, var(--surface) 0%, var(--dark2) 100%);
      border-top-left-radius: 200px; border-top-right-radius: 200px; border: 1px solid var(--border); border-bottom: none;
    }
    .hero-photo { position: relative; z-index: 2; width: 85%; max-width: 420px; filter: drop-shadow(0 40px 60px rgba(0,0,0,0.5)); }
    .float-card { position: absolute; z-index: 3; background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 12px 16px; backdrop-filter: blur(8px); }
    .float-card-1 { top: 22%; right: 4%; }
    .float-card-2 { bottom: 18%; left: 4%; }
    .fc-label { font-size: 0.58rem; color: var(--muted); text-transform: uppercase; margin-bottom: 3px; }
    .fc-value { font-weight: 700; color: var(--cream); font-family: 'Syne', sans-serif; }
    .fc-dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: #22C55E; margin-right: 5px; }

    /* Ticker */
    .ticker-wrap { background: var(--orange); padding: 14px 0; overflow: hidden; }
    .ticker-track { display: flex; animation: ticker 28s linear infinite; width: max-content; }
    .ticker-item { font-family: 'Syne', sans-serif; font-size: 0.72rem; font-weight: 700; color: #fff; padding: 0 2.5rem; display: flex; align-items: center; gap: 2.5rem; text-transform: uppercase; }
    .ticker-item::after { content: '✦'; opacity: 0.7; }
    @keyframes ticker { from { transform: translateX(0); } to { transform: translateX(-50%); } }

    /* Services */
    .services { background: var(--dark2); }
    .services-intro { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: end; margin-bottom: 64px; }
    .services-headline { font-size: clamp(2.2rem, 4vw, 3.4rem); font-weight: 800; color: var(--cream); line-height: 1.1; }
    .services-headline em { color: var(--orange); font-style: italic; }
    .services-text { color: var(--muted); line-height: 1.85; }
    .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--border); border: 1px solid var(--border); }
    .service-card { background: var(--dark2); padding: 2.5rem 2rem; transition: 0.3s; position: relative; }
    .service-card:hover { background: var(--surface); }
    .service-card::before { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 2px; background: var(--orange); transform: scaleX(0); transition: 0.4s; transform-origin: left; }
    .service-card:hover::before { transform: scaleX(1); }
    .service-icon { font-size: 1.8rem; margin-bottom: 1.2rem; display: block; }
    .service-name { font-family: 'Syne', sans-serif; font-weight: 700; color: var(--cream); margin-bottom: 0.75rem; }
    .service-desc { font-size: 0.85rem; color: var(--muted); line-height: 1.75; }
    .service-tag { display: inline-block; margin-top: 1.2rem; font-size: 0.6rem; font-weight: 600; color: var(--orange); text-transform: uppercase; letter-spacing: 0.18em; }

    /* About Strip */
    .about-strip { display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center; }
    .about-photo-wrap { position: relative; }
    .about-photo-wrap img { width: 100%; border-radius: 4px; filter: grayscale(15%); transition: 0.4s; }
    .about-photo-wrap:hover img { filter: grayscale(0%); }
    .about-exp-badge { position: absolute; bottom: -20px; right: -20px; background: var(--orange); padding: 1.2rem 1.5rem; text-align: center; }
    .about-exp-num { font-family: 'Syne', sans-serif; font-size: 2rem; font-weight: 800; color: #fff; line-height: 1; }
    .about-exp-label { font-size: 0.58rem; font-weight: 600; color: rgba(255,255,255,0.8); text-transform: uppercase; margin-top: 3px; }
    .about-headline { font-size: clamp(1.8rem, 3vw, 2.8rem); font-weight: 800; color: var(--cream); line-height: 1.12; margin-bottom: 1.5rem; }
    .about-headline em { color: var(--orange); font-style: italic; }
    .about-body { color: var(--muted); line-height: 1.9; margin-bottom: 2rem; }
    .about-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 2.5rem; }
    .about-tag { font-size: 0.68rem; color: var(--text); padding: 6px 14px; border: 1px solid var(--border); text-transform: uppercase; transition: 0.25s; }
    .about-tag:hover { border-color: var(--border-o); color: var(--orange); }
    .btn-cv { display: inline-flex; align-items: center; gap: 10px; padding: 0.9rem 1.8rem; border: 1px solid var(--border); color: var(--cream); text-transform: uppercase; font-weight: 600; transition: 0.3s; }
    .btn-cv:hover { border-color: var(--orange); color: var(--orange); transform: translateY(-2px); }

    /* CTA Banner */
    .cta-banner { background: var(--dark2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 80px 7%; display: grid; grid-template-columns: 1fr auto; gap: 3rem; align-items: center; position: relative; overflow: hidden; }
    .cta-headline { font-size: clamp(1.8rem, 3.5vw, 3rem); font-weight: 800; color: var(--cream); line-height: 1.15; }
    .cta-headline em { color: var(--orange); font-style: italic; }
    .cta-sub { color: var(--muted); margin-top: 0.75rem; }
    .cta-actions { display: flex; flex-direction: column; gap: 12px; align-items: flex-end; }
    .btn-cta-main { background: var(--orange); color: #fff; padding: 1.1rem 2.4rem; font-weight: 600; text-transform: uppercase; transition: 0.3s; }
    .btn-cta-wa { color: var(--muted); display: flex; align-items: center; gap: 6px; text-transform: uppercase; font-size: 0.72rem; }

    /* Responsive Overrides */
    @media(max-width: 1024px) {
      .hero { grid-template-columns: 1fr; }
      .hero-right { height: 480px; order: -1; padding-top: calc(var(--nav-h) + 20px); }
      .hero-left { padding: 40px 7% 80px; text-align: center; }
      .hero-actions { justify-content: center; }
      .hero-stats { justify-content: center; }
      .services-intro { grid-template-columns: 1fr; }
      .services-grid { grid-template-columns: 1fr 1fr; }
      .about-strip { grid-template-columns: 1fr; gap: 4rem; }
      .cta-banner { grid-template-columns: 1fr; text-align: center; }
      .cta-actions { align-items: center; }
    }
    @media(max-width: 640px) {
      .services-grid { grid-template-columns: 1fr; }
      .hero-photo { width: 70%; }
    }
  </style>
</Layout>
