---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="Digital Business Card of Imam Hasan Tahim" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet"/>

    <style>
      body {
        margin: 0;
        padding: 0;
        background-color: var(--dark);
        color: var(--white);
        font-family: 'Outfit', sans-serif;
        overflow-x: hidden;
      }
      
      /* VCard specific adjustments */
      main {
        max-width: 500px;
        margin: 0 auto;
        min-height: 100vh;
        background: linear-gradient(180deg, rgba(20,20,20,1) 0%, rgba(10,10,10,1) 100%);
        box-shadow: 0 0 50px rgba(0,0,0,0.5);
      }
    </style>
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
